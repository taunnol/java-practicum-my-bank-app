{
  "realm": "bank",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "ACCOUNTS_ACCESS", "description": "Доступ к Accounts API" },
      { "name": "CASH_ACCESS", "description": "Доступ к Cash API" },
      { "name": "TRANSFER_ACCESS", "description": "Доступ к Transfer API" },
      { "name": "CALL_ACCOUNTS", "description": "Межсервисный доступ к Accounts internal API" },
      { "name": "CALL_NOTIFICATIONS", "description": "Межсервисный доступ к Notifications API" }
    ]
  },
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "firstName": "Абоба",
      "lastName": "Тестовый",
      "email": "testuser@bank.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ACCOUNTS_ACCESS", "CASH_ACCESS", "TRANSFER_ACCESS"]
    },
    {
      "username": "petrov",
      "enabled": true,
      "firstName": "Петя",
      "lastName": "Петров",
      "email": "petrov@bank.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ACCOUNTS_ACCESS", "CASH_ACCESS", "TRANSFER_ACCESS"]
    },
    {
      "username": "ivanov",
      "enabled": true,
      "firstName": "Иван",
      "lastName": "Иванов",
      "email": "ivanov@bank.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ACCOUNTS_ACCESS", "CASH_ACCESS", "TRANSFER_ACCESS"]
    },
    {
      "username": "olegov",
      "enabled": true,
      "firstName": "Олег",
      "lastName": "Олегов",
      "email": "olegov@bank.local",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["ACCOUNTS_ACCESS", "CASH_ACCESS", "TRANSFER_ACCESS"]
    }
  ],
  "clients": [
    {
      "clientId": "front-ui",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["http://localhost:8080"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email"]
    },
    {
      "clientId": "cash-service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "cash-service-secret",
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid"]
    },
    {
      "clientId": "transfer-service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "transfer-service-secret",
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid"]
    },
    {
      "clientId": "accounts-service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "accounts-service-secret",
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid"]
    }
  ],
  "scopeMappings": [
    {
      "clientScope": "openid",
      "roles": []
    }
  ],
  "clientScopeMappings": {
    "cash-service": [
      { "client": false, "roles": ["CALL_ACCOUNTS", "CALL_NOTIFICATIONS"] }
    ],
    "transfer-service": [
      { "client": false, "roles": ["CALL_ACCOUNTS", "CALL_NOTIFICATIONS"] }
    ],
    "accounts-service": [
      { "client": false, "roles": ["CALL_NOTIFICATIONS"] }
    ]
  }
}
